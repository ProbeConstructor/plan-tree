{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "plan-tree",
  "version": "1.1.5",
  "identifier": "dev.tyto.plan-tree",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "plan-tree",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "style-src": "'unsafe-inline' 'self'",
        "script-src": "'self'",
        "img-src": "'self' data: blob:",
        "object-src": "'none'",
        "frame-src": "'none'",
        "connect-src": "'self' ipc: http://ipc.localhost https://api.github.com https://github.com",
        "font-src": "'self' data:"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/ProbeConstructor/plan-tree/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDNEY4QzVGMkFBNjgzQTkKUldTcGc2WXFYNHhQckdRTkUzYnZOeUpzejhHRVEyNTdoN3NrN2ZHWjNncVI2Zlp6RzhjVkJ6TzIK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["appimage", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
